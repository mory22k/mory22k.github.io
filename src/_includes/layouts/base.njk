{%- set rootPath = page.url | relativeRoot -%}
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="{{ description }}"/>
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ rootPath }}styles.css"/>
    <script src="{{ rootPath }}script.js" defer></script>
    {% include "javascripts/katex.njk" %}
  </head>
  <body>
    {% include "header.njk" %}
    {{ content | safe }}
    {% include "footer.njk" %}
  </body>
</html>
